# Build and output
/build/
/dist/
/out/
# Do not use blanket *.dll / *.so / *.obj — Unity stores plugins and mesh assets under Assets/
/build/**/*.exe
/dist/**/*.exe
/out/**/*.exe
/build/**/*.dll
/dist/**/*.dll
/out/**/*.dll
/build/**/*.so
/dist/**/*.so
/out/**/*.so
/build/**/*.dylib
/dist/**/*.dylib
/out/**/*.dylib
# Root-level executables only (does not ignore paths like Assets/...)
/*.exe
*.o
*.a
*.lib

# IDEs and editors
.idea/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs and temp
*.log
*.tmp
*.temp
*.swp
*~

# Optional: uncomment when you choose a stack
# Node
# node_modules/
# .env
# .env.local
# Python
# __pycache__/
# .venv/
# venv/
# *.pyc

# Unity editor recovery scenes (should not be versioned)
/[Aa]ssets/_Recovery/

# --- Unity (https://github.com/github/gitignore/blob/main/Unity.gitignore) ---
